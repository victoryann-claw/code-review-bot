# Server Configuration
PORT=3000

# GitHub Configuration
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo (full control)
GITHUB_TOKEN=your_github_token_here

# GitHub Webhook Secret
# Generate a secure random string and configure it in your GitHub webhook settings
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# LLM Provider Configuration
# Options: openai, minimax (default: openai)
LLM_PROVIDER=openai

# OpenAI Configuration (if LLM_PROVIDER=openai)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# MiniMax Configuration (if LLM_PROVIDER=minimax)
# Get your API key at: https://platform.minimax.chat
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=MiniMax-Text-01

# Optional: Enable debug logging
DEBUG=false
